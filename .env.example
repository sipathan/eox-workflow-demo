# --- Database (PostgreSQL) ---
# Prisma reads DATABASE_URL from the environment (local shell, Docker Compose, or EC2).
#
# Local development (Postgres listening on localhost:5432):
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"
#
# Default user/db/password used by `docker-compose.yml` for the bundled Postgres service.
# Compose maps host **localhost:5432** → container **5432** so Prisma on your laptop can connect.
DATABASE_URL="postgresql://eox:eox@localhost:5432/eox_workflow?schema=public"
# Pilot/local cookie settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
#
# Inside the Compose **app** container, Compose sets DATABASE_URL to hostname `postgres`
# (the db service name). You normally do not need to change that.

# --- App ---
# Used for signing demo session cookies (use 32+ random characters for anything shared).
SESSION_SECRET="local-demo-session-secret-32chars-minimum-ok"
#
# Full demo reset (same 10 users + 15 cases every time): from repo root run `npm run db:reset`
# (requires Postgres up and this DATABASE_URL). EC2 Compose: `docker compose exec app npx prisma migrate reset --force`
# or `./scripts/demo-reset-docker.sh` — see docs/HANDOFF_CURRENT_STATE.md.
#
# Demo persona switcher (dashboard header): set to exactly `true` to enable instant switching
# between the 10 seeded users without re-entering password. Leave unset or `false` for normal
# behavior (password login only; no switcher UI; server rejects persona-switch posts).
DEMO_MODE=false
