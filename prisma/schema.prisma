// EoX Workflow — normalized roles + teams for future SSO (`externalIdentityId`) and enterprise groups.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  ACCOUNT_TEAM
  CX_OPS
  BU_CONTRIBUTOR
  FINANCE_APPROVER
  LEADERSHIP_READONLY
  PLATFORM_ADMIN
}

enum TeamType {
  CX_OPERATIONS
  BU_QUEUE
  FINANCE
  LEADERSHIP
  PLATFORM_ADMIN
}

enum RequestType {
  EoVSS
  EoSM
  /// Extended Support Services / MSS (combined bucket; UI label ESS/MSS). MSS-specific workflow may branch later via `essSupportSubtype` and flags.
  ESS_MSS
}

/// ESS/MSS intake: what is in scope for this request (hardware, software, or both).
enum EssMssSupportSubtype {
  HARDWARE
  SOFTWARE
  HARDWARE_AND_SOFTWARE
}

enum CaseStatus {
  Draft
  Submitted
  InReview       @map("In Review")
  AwaitingInfo    @map("Awaiting Info")
  InProgress      @map("In Progress")
  Blocked
  ReadyForRelease @map("Ready for Release")
  Closed
  Rejected
  Cancelled
}

enum Priority {
  Low
  Medium
  High
  Critical
}

enum TaskType {
  IntakeValidation       @map("Intake Validation")
  /// ESS/MSS (and future MSS subflows): eligibility / scope review — subtype-specific copy lives in `Task.notes` at creation.
  EligibilityReview      @map("Eligibility Review")
  BUReview               @map("BU Review")
  BUPricing              @map("BU Pricing")
  QuoteTracking          @map("Quote Tracking")
  VAPTracking            @map("VAP Tracking")
  FlagRemovalTracking    @map("Flag Removal Tracking")
  AdditionalInfoRequest  @map("Additional Info Request")
}

enum TaskStatus {
  NotStarted   @map("Not Started")
  InProgress   @map("In Progress")
  Completed
  Blocked
  NotRequired  @map("Not Required")
}

enum ExternalReferenceType {
  QUOTE_ID
  VAP_ID
  APAS_NPI
}

/// Commercial outcome for quote / booking tracking (case-level).
enum QuoteBookingStatus {
  OPEN
  BOOKED
  NOT_BOOKED
  PASSED_OVER
}

model User {
  id                   String    @id @default(cuid())
  externalIdentityId   String?   @unique
  name                 String
  email                String    @unique
  passwordHash         String
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  roles          UserRole[]
  teams          UserTeam[]
  casesRequested Case[]       @relation("CaseRequester")
  casesOwned     Case[]       @relation("CaseOwner")
  tasksOwned     Task[]       @relation("TaskOwner")
  /// Direct assignments to tasks (many-to-many); complements optional `Task.ownerId`.
  taskAssignments   TaskAssignee[] @relation("TaskAssigneeUser")
  taskAssigneesAuthored TaskAssignee[] @relation("TaskAssigneeAssignedBy")
  comments       Comment[]
  activities     ActivityLog[]
  attachments    Attachment[]
}

model Role {
  id        String     @id @default(cuid())
  key       RoleKey    @unique
  name      String
  userRoles UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model Team {
  id           String   @id @default(cuid())
  name         String
  type         TeamType
  region       String?
  businessUnit String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members UserTeam[]
  cases   Case[]       @relation("CaseTeam")
  tasks   Task[]       @relation("TaskTeam")

  @@index([type])
}

model UserTeam {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

/// One operational request. Platform-specific details live on `CaseAsset` rows.
model Case {
  id                    String      @id @default(cuid())
  caseId                String      @unique
  requestType           RequestType
  customerName          String
  dealId                String?
  platform              String?
  softwareVersion       String?
  status                CaseStatus  @default(Draft)
  priority              Priority    @default(Medium)
  requesterId           String
  ownerId               String?
  assignedTeamId        String?
  extensionStartDate    DateTime?
  extensionEndDate      DateTime?
  businessJustification String
  /// EoVSS/EoSM: optional supporting details. ESS_MSS: migration plan summary/details (required on submit in app validation).
  migrationPlan         String?
  /// ESS/MSS only: hardware / software / both. Null for EoVSS/EoSM.
  essSupportSubtype     EssMssSupportSubtype?
  /// ESS/MSS: key dates or rollout window for migration planning.
  migrationTimeline     String?
  /// ESS/MSS: planned replacement offering, if known.
  targetReplacementProduct String?
  /// ESS/MSS: assessed install site when hardware is in scope (subtype HARDWARE or HARDWARE_AND_SOFTWARE).
  hardwarePhysicalLocation String?
  /// ESS/MSS: how software is deployed when software is in scope.
  softwareDeploymentType String?
  /// ESS/MSS: application family / product type for software scope.
  softwareProductFamily String?
  /// Declared: on-premise (ESS software rules).
  softwareOnPremise       Boolean?
  /// Declared: perpetual license.
  softwarePerpetualLicense Boolean?
  /// Declared: application software (not network OS).
  softwareIsApplicationSoftware Boolean?
  /// Declared: not IOS / IOS-XR.
  softwareNotIosIosXr   Boolean?
  /// True = production use; false = lab/non-production (review / non-compliant path in UI).
  environmentIsProduction Boolean?
  /// User confirmed review when eligibility is non-default (e.g. lab, or declaration exceptions).
  essEligibilityAcknowledged Boolean @default(false)
  /// Optional for all request types (EoVSS, EoSM, ESS_MSS); must not block intake submit, draft save, or other case updates in this app.
  partnerName           String?
  eolBulletinLink       String?
  serialNumbers         String?
  supportCoverageIndicator String?
  hwLdosDate            DateTime?
  notes                 String?
  /// Optional CX routing / assignment context (distinct from intake `notes`). Editable on case detail by CX Ops / Platform Admin.
  routingNote           String?
  quoteBookingStatus    QuoteBookingStatus @default(OPEN)
  /// Required in app validation when `quoteBookingStatus` is NOT_BOOKED or PASSED_OVER; otherwise null.
  notBookedReason       String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  requester    User        @relation("CaseRequester", fields: [requesterId], references: [id])
  owner        User?       @relation("CaseOwner", fields: [ownerId], references: [id])
  assignedTeam Team?       @relation("CaseTeam", fields: [assignedTeamId], references: [id])
  assets       CaseAsset[]

  tasks       Task[]
  comments    Comment[]
  activities  ActivityLog[]
  attachments Attachment[]
  references  ExternalReference[]

  @@index([status])
  @@index([requestType])
  @@index([assignedTeamId])
  @@index([ownerId])
  @@index([requesterId])
  @@index([quoteBookingStatus])
}

/// A platform / asset line item on a case (multi-platform support).
model CaseAsset {
  id              String    @id @default(cuid())
  caseId          String
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sortOrder       Int       @default(0)
  platformName    String
  serialNumbers   String?
  eolBulletinLink String?
  hwLdosDate      DateTime?
  softwareVersion String?
  /// Optional units / count for this platform line (not case-wide). Null when unset.
  quantity        Int?
  /// Demo currency: USD; two decimal places enforced in app helpers.
  buCost          Float     @default(0)
  cxCost          Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks Task[]

  @@index([caseId])
}

model Task {
  id                String      @id @default(cuid())
  caseId            String
  case              Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseAssetId       String?
  caseAsset         CaseAsset?  @relation(fields: [caseAssetId], references: [id])
  type              TaskType
  status            TaskStatus  @default(NotStarted)
  /// When true, the task participates in the activation chain and completion gates (inactive tasks are ignored until activated).
  isRunnable        Boolean     @default(false)
  /// First moment the task became runnable (used for “days active” in the UI).
  activatedAt       DateTime?
  ownerId           String?
  owner             User?       @relation("TaskOwner", fields: [ownerId], references: [id])
  assignedTeamId    String?
  assignedTeam      Team?       @relation("TaskTeam", fields: [assignedTeamId], references: [id])
  isRequired        Boolean     @default(true)
  dueDate           DateTime?
  notes             String?
  blockerReason     String?
  notRequiredReason String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  assignees TaskAssignee[]
  references ExternalReference[]

  @@index([caseId])
  @@index([caseAssetId])
  @@index([assignedTeamId])
  @@index([ownerId])
}

/// Many-to-many: one workflow task may be directly assigned to multiple users (shared task row).
model TaskAssignee {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation("TaskAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt     DateTime @default(now())
  assignedById   String?
  assignedBy     User?    @relation("TaskAssigneeAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([caseId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([caseId])
}

model Attachment {
  id           String   @id @default(cuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  mimeType     String?
  sizeBytes    Int?
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([caseId])
}

model ExternalReference {
  id              String                  @id @default(cuid())
  caseId          String
  case            Case                    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?                   @relation(fields: [taskId], references: [id])
  referenceType   ExternalReferenceType
  referenceId     String
  externalStatus  String?
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([caseId])
  @@index([taskId])
}
